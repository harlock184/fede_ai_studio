# =============================================================
# FEDE AI STUDIO — variables de entorno (ejemplo)
# Copia este archivo a `.env.local` y rellena los valores.
# NUNCA subas `.env.local` al repo.
# =============================================================

# --- Sitio ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase (FASE 3: prospectos + asistente IA) ---
# Aún no se usa en la v1 del sitio. Se activa cuando cableemos
# el formulario de contacto y el chat del asistente.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Contacto / notificaciones (FASE 2) ---
# Correo destino para los leads del formulario de contacto.
CONTACT_TO_EMAIL=
